# Runtime data source
DATA_STORE=local
# DATA_STORE=google_sheets

# Google Sheets service account (KHÔNG commit file .env thật)
GOOGLE_SHEET_ID=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Server-side auth/RBAC V4.6
# Set AUTH_ENABLED=true on Vercel Preview/Staging/Production.
AUTH_ENABLED=true
AUTH_SESSION_SECRET=
AUTH_SESSION_MAX_AGE_HOURS=12
AUTH_CEO_USERNAME=
AUTH_CEO_PASSWORD=
AUTH_CEO_NAME=CEO
AUTH_ACCOUNTANT_USERNAME=
AUTH_ACCOUNTANT_PASSWORD=
AUTH_ACCOUNTANT_NAME=Kế toán

# AI Agent V4.6.2
# Recommended for this project: Gemini 2.5 Flash.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional fallback if switching provider later. Leave blank when using Gemini.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Telegram report sender
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Legacy V4.5.1 temporary basic auth variables.
# Deprecated in V4.6; kept only for old check endpoint compatibility.
APP_BASIC_AUTH_ENABLED=false
APP_USERNAME=
APP_PASSWORD=
